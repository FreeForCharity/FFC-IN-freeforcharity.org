# freeforcharity.org — Apache config for the Next.js static export
# served from InterServer cPanel alongside WHMCS at /hub/.
#
# This file is part of the static export (lives in public/ so it ships
# inside out/ during `next build`). When deployed to cPanel's document
# root it controls URL rewriting, redirects, and cache behavior for the
# entire apex domain except /hub/, which is delegated to WHMCS.

RewriteEngine On
Options -Indexes
ServerSignature Off

# ---------------------------------------------------------------------
# Hand-off /hub/ to WHMCS untouched
# ---------------------------------------------------------------------
# Anything under /hub/ is WHMCS billing/store/admin. Stop processing
# immediately so the rules below cannot accidentally rewrite it.
RewriteRule ^hub($|/) - [L]

# ---------------------------------------------------------------------
# Force HTTPS (Cloudflare proxy already does this, but defense-in-depth
# in case the proxy is disabled or someone hits the origin directly)
# ---------------------------------------------------------------------
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ---------------------------------------------------------------------
# WP → Next.js URL redirects (source: docs/cutover-redirects.csv)
# Apply BEFORE the trailing-slash / .html rewriting below so Apache
# does not try to find static files for old WordPress paths.
# ---------------------------------------------------------------------

# Slug changes
RewriteRule ^free-for-charity-terms-of-service/?$ /terms-of-service [R=301,L]
RewriteRule ^charity-and-nonprofit-case-studies-to-help-your-organization-succeed/?$ /charity-and-nonprofit-case-studies [R=301,L]

# PayPal callbacks (302 + preserve query string with QSA)
RewriteRule ^donation-confirmation/?$ /donate [R=302,L,QSA]
RewriteRule ^donation-failed/?$ /donate [R=302,L,QSA]

# Legacy WP blog posts → /blog
RewriteRule ^free-for-charity-just-earned-the-platinum-seal-of-transparency/?$ /blog [R=301,L]
RewriteRule ^our-organization-earned-a-2021-platinum-seal-of-transparency/?$ /blog [R=301,L]
RewriteRule ^we-just-updated-for-the-2022-guidestar-platinum-seal/?$ /blog [R=301,L]
RewriteRule ^using-a-registered-agent-service-northwest-registered-agent/?$ /blog [R=301,L]

# Content consolidation
RewriteRule ^podio-sponsorship-program/?$ /help-for-charities [R=301,L]
RewriteRule ^what-is-the-cost/?$ /help-for-charities [R=301,L]
RewriteRule ^donor-dashboard/?$ /donate [R=301,L]
RewriteRule ^submit-information/?$ /contact-us [R=301,L]

# Testimonials inlined on homepage
RewriteRule ^testimonial/american-legion-ahwatukee-post-64/?$ /#testimonials [R=301,L]
RewriteRule ^testimonial/keith-ray/?$ /#testimonials [R=301,L]
RewriteRule ^testimonial/pardhasaradhi-namburi/?$ /#testimonials [R=301,L]
RewriteRule ^testimonial/tashonda-payne/?$ /#testimonials [R=301,L]

# Dropped WP archives + plumbing → home
RewriteRule ^author/(adagraves|admin|clarkemoyer|globaladmin|joel|tempmigrationadmin)/?$ / [R=301,L]
RewriteRule ^category/uncategorized/?$ /blog [R=301,L]
RewriteRule ^layout_type/(row|section)/?$ / [R=301,L]
RewriteRule ^module_width/regular/?$ / [R=301,L]
RewriteRule ^scope/not_global/?$ / [R=301,L]
RewriteRule ^sample-page/?$ / [R=301,L]
RewriteRule ^codetest/?$ / [R=301,L]
RewriteRule ^__qs/?$ / [R=301,L]

# Block legacy WordPress admin/include paths (defense-in-depth in case
# any old WP files linger in public_html after the deploy swap)
RewriteRule ^wp-admin(/|$) / [R=301,L]
RewriteRule ^wp-includes/ - [F,L]
RewriteRule ^wp-content/(plugins|themes|mu-plugins)/ - [F,L]
RewriteRule ^xmlrpc\.php$ - [F,L]
RewriteRule ^wp-login\.php$ - [F,L]

# ---------------------------------------------------------------------
# Next.js static export URL handling
# ---------------------------------------------------------------------
# The export emits /about-us.html (no trailing slash). Mirror that on
# Apache: strip trailing slashes, then resolve clean URLs to their
# .html files.

# Strip trailing slash on non-directory URLs (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Append .html when a matching file exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Custom 404 page generated by next build
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------
# Cache + compression
# ---------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml font/ttf font/otf
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
</IfModule>

# Hashed Next.js asset files are safe to cache forever
<FilesMatch "\.(js|css|woff2|ttf|webp|svg|png|jpg|jpeg|gif|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Never cache HTML
<FilesMatch "\.html$">
  Header set Cache-Control "public, max-age=300, must-revalidate"
</FilesMatch>

# ---------------------------------------------------------------------
# Security headers (Cloudflare adds some; these are origin-side defaults)
# ---------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
