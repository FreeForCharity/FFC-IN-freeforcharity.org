{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost/",
        "http://localhost/about-us/",
        "http://localhost/contact-us/",
        "http://localhost/donate/",
        "http://localhost/volunteer/",
        "http://localhost/free-charity-web-hosting/",
        "http://localhost/privacy-policy/",
        "http://localhost/blog/",
        "http://localhost/domains/",
        "http://localhost/help-for-charities/"
      ],
      "numberOfRuns": 3
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}
